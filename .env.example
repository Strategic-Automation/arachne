# Arachne Environment Variables
# Copy this file to .env and fill in your values.
#
# PRECEDENCE: Environment (export VAR=val) > .env > arachne.yaml
# Use .env for secrets and per-machine overrides; arachne.yaml for team-shared defaults.
#
# LLM Configuration (overrides arachne.yaml)
LLM_BACKEND=openrouter
LLM_MODEL=qwen/qwen3.6-plus:free
LLM_API_KEY=your_openrouter_api_key_here
LLM_BASE_URL=https://openrouter.ai/api/v1/
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# -- Browser LLM (Independent) --
# BROWSER_LLM_MODEL=openai/gpt-4o-mini
# BROWSER_LLM_API_KEY=your_api_key_here
# BROWSER_LLM_BASE_URL=https://openrouter.ai/api/v1/
# BROWSER_LLM_BACKEND=openrouter
# Lower temperature (0.0–0.5) recommended for more deterministic browser automation
# ARACHNE_BROWSER_LLM_TEMPERATURE=0.3
# Separate fallback model used when primary model fails structured output parsing
# ARACHNE_BROWSER_LLM_FALLBACK_MODEL=xiaomi/mimo-v2.5

# Langfuse Observability (Optional)
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_SAMPLE_RATE=1.0

# Cost Settings
ARACHNE_COST_DEFAULT_MAX_USD=10.0
ARACHNE_COST_DEFAULT_MAX_TOKENS=500000

# MCP Settings (JSON format)
# Example: ARACHNE_MCP_SERVERS='{"math":{"command":"npx","args":["-y","@modelcontextprotocol/server-math"]}}'
ARACHNE_MCP_SERVERS={}

# Session Settings (override defaults)
ARACHNE_SESSION_DIRECTORY=/home/youruser/.local/share/arachne/sessions

# Skill Settings (override defaults)
ARACHNE_SKILL_DIRECTORY=/home/youruser/.local/share/arachne/skills

# Web Search Tools
JINA_API_KEY=your_jina_api_key_here
SERPAPI_API_KEY=your_serpapi_api_key_here
