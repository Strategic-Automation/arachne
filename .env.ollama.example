# =====================================================
# Arachne -- Environment Configuration (Ollama)
# =====================================================

# -- LLM Provider: Ollama (local, no API key needed) --
LLM_BACKEND=ollama
LLM_MODEL=ollama_chat/qwen3.5:4b
LLM_API_KEY=
LLM_BASE_URL=http://localhost:11434
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# -- Browser LLM (Independent) --
# BROWSER_LLM_BACKEND=ollama
# BROWSER_LLM_MODEL=ollama_chat/llama3:8b
# BROWSER_LLM_BASE_URL=http://localhost:11434

# -- Langfuse (disabled by default) --
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# -- Cost Enforcement --
ARACHNE_COST_DEFAULT_MAX_USD=10.0
ARACHNE_COST_DEFAULT_MAX_TOKENS=500000
ARACHNE_COST_HARD_STOP_ENABLED=true

# -- Web UI --
ARACHNE_UI_ENABLED=true
ARACHNE_UI_PORT=8174

# -- Browser Node --
ARACHNE_BROWSER_HEADLESS=true
ARACHNE_BROWSER_TIMEOUT_MS=30000

# -- Checkpoints --
ARACHNE_CHECKPOINT_ENABLED=true
ARACHNE_CHECKPOINT_INTERVAL_SECONDS=30.0

# -- Logging --
ARACHNE_LOG_ENABLED=true
ARACHNE_LOG_LEVEL=INFO
